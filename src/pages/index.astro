---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Bagian Welcome & Portfolio -->
  <div class="flex flex-col items-start space-y-6 p-8">
    <div class="flex items-center justify-start">
      <div>
        <img 
          src="/portfolio-image.jpg" 
          alt="A representation of my work" 
          class="w-48 h-auto rounded-lg shadow-lg object-cover" />
      </div>
      <div class="ml-4">
        <h1 class="text-4xl font-bold">Welcome to My Portfolio</h1>
        <p class="mt-2">Hi, I'm Daffarizqy Prastowiyono, a Student of software engineering.</p>

        <!-- Tombol Sosial Media -->
        <div class="flex flex-col items-start space-y-6">
          <div class="flex justify-center items-center bg-gray-100 shadow-md p-4 rounded-full space-x-4">
            <!-- Tombol GitHub -->
            <a href="https://github.com/daffariz316" target="_blank" class="flex justify-center items-center w-12 h-12 rounded-full bg-gray-800 text-white shadow hover:bg-gray-900 transition">
              <i class="fab fa-github text-xl"></i>
            </a>
            <!-- Tombol LinkedIn -->
            <a href="https://www.linkedin.com/in/daffarizqy-prastowiyono/" target="_blank" class="flex justify-center items-center w-12 h-12 rounded-full bg-blue-700 text-white shadow hover:bg-blue-800 transition">
              <i class="fab fa-linkedin-in text-xl"></i>
            </a>
            <!-- Tombol WhatsApp -->
            <a href="https://wa.me/62895372499072" class="flex justify-center items-center w-12 h-12 rounded-full bg-green-500 text-white shadow hover:bg-green-600 transition">
              <i class="fab fa-whatsapp text-xl"></i>
            </a>
            <!-- Tombol Instagram -->
            <a href="https://www.instagram.com/drz_pras" target="_blank" class="flex justify-center items-center w-12 h-12 rounded-full bg-pink-600 text-white shadow hover:bg-pink-700 transition">
              <i class="fab fa-instagram text-xl"></i>
            </a>
          </div>
        </div>

        <!-- Tombol Download CV -->
        <div class="mt-6">
          <a href="/CV-Daffarizqy-Prastowiyono.pdf" download="CV-Daffarizqy-Prastowiyono.pdf" class="bg-amber-600 text-white p-3 rounded-3xl hover:bg-amber-700 transition">
            <i class="fas fa-download text-lg"></i>
            Download CV
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bagian About Me -->
  <section class="container mx-auto p-8">
  <div class="bg-white shadow-lg p-8 rounded-lg dark:bg-gray-700 dark:shadow-xl dark:border dark:border-gray-700">
    <div class="text-center">
      <h1 class="text-4xl font-bold mb-4 text-amber-600 dark:text-amber-300">About Me</h1>
      <p class="text-lg text-gray-700 max-w-3xl mx-auto dark:text-gray-300">
        Hi, I'm Daffarizqy Prastowiyono, a passionate junior backend developer who loves solving problems with efficient solutions. Welcome to my portfolio!
      </p>
    </div>

    <!-- Profile Section -->
    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <!-- Profile Image -->
      <div class="flex justify-center">
        <img 
        src="/portfolio-image.jpg" 
        alt="A representation of my work" 
        class="w-48 h-auto rounded-lg shadow-lg object-cover dark:shadow-xl" />
      </div>

      <!-- Description -->
      <div>
        <h2 class="text-3xl font-semibold text-gray-800 mb-4 dark:text-gray-100">Who Am I?</h2>
        <p class="text-gray-600 mb-4 dark:text-gray-300">
          I specialize in backend development, focusing on creating reliable, scalable, and maintainable systems. My journey in programming began out of curiosity and quickly turned into a passion for building innovative software.
        </p>
        <p class="text-gray-600 dark:text-gray-300">
          Currently, I am exploring advanced backend technologies and cloud computing. In my free time, I enjoy learning new programming languages, reading tech blogs, and working on personal projects.
        </p>
      </div>
    </div>
  </div>

  <!-- Skills Section -->
  <div class="mt-12 bg-gray-50 shadow-lg p-8 rounded-lg dark:bg-gray-700 dark:shadow-xl dark:border dark:border-gray-600">
    <h2 class="text-3xl font-semibold text-gray-800 mb-6 text-center dark:text-gray-100">My Skills</h2>
    <!-- Frontend Section -->
    <div class="mb-8">
      <h3 class="text-2xl font-semibold text-gray-800 mb-4 dark:text-gray-100">Frontend</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 text-center">
        <!-- HTML -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fa-brands fa-html5 text-4xl text-orange-400 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">HTML</p>
        </div>
        <!-- CSS -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fa-brands fa-css3-alt text-4xl text-blue-500 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">CSS</p>
        </div>
        <!-- JavaScript -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fab fa-js-square text-4xl text-yellow-500 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">JavaScript</p>
        </div>
        <!-- Astro.js -->
        <div class="relative bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <div class="absolute -top-4 -right-4 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full shadow-lg">
            New
          </div>
          <i class="fas fa-asterisk text-4xl text-orange-500 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">Astro.js</p>
        </div>
      </div>
    </div>

    <!-- Backend Section -->
    <div class="mb-8">
      <h3 class="text-2xl font-semibold text-gray-800 mb-4 dark:text-gray-100">Backend</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 text-center">
        <!-- Laravel -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fab fa-laravel text-4xl text-red-600 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">Laravel</p>
        </div>
        <!-- MySQL -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fas fa-database text-4xl text-blue-400 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">MySQL</p>
        </div>
        <!-- MongoDB -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fas fa-leaf text-4xl text-green-500 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">MongoDB</p>
        </div>
        <!-- RESTful APIs -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fas fa-cogs text-4xl text-gray-600 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">RESTful APIs</p>
        </div>
      </div>
    </div>

    <!-- Desktop Application Section -->
    <div class="mb-8">
      <h3 class="text-2xl font-semibold text-gray-800 mb-4 dark:text-gray-100">Desktop Application</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 text-center">
        <!-- VB.net -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fas fa-code text-4xl text-blue-600 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">VB.net</p>
        </div>
      </div>
    </div>

    <!-- Data Analysis Section -->
    <div class="mb-8">
      <h3 class="text-2xl font-semibold text-gray-800 mb-4 dark:text-gray-100">Data Analysis</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 text-center">
        <!-- R Studio -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fas fa-chart-line text-4xl text-blue-500 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">R Studio</p>
        </div>
        <!-- Python -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fab fa-python text-4xl text-green-600 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">Python</p>
        </div>
      </div>
    </div>

    <!-- Others Section -->
    <div class="mb-8">
      <h3 class="text-2xl font-semibold text-gray-800 mb-4 dark:text-gray-100">Others</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 text-center">
        <!-- Figma -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fab fa-figma text-4xl text-purple-500 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">Figma</p>
        </div>
        <!-- Office -->
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fas fa-file-word text-4xl text-blue-600 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">Microsoft Office</p>
        </div>
        <div class="bg-white shadow-md p-6 rounded-lg flex flex-col items-center dark:bg-gray-800 dark:shadow-xl dark:border dark:border-gray-600">
          <i class="fas fa-ad text-4xl text-yellow-500 mb-4"></i>
          <p class="font-medium text-gray-800 dark:text-gray-200">Digital Marketing</p>
        </div>
      </div>
    </div>
  </div>
  </section>
</BaseLayout>
