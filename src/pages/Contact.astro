---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="container mx-auto p-8 border border-slate-300 rounded-lg shadow-md bg-white">
    <!-- Header Contact Section -->
    <div class="text-center">
      <h1 class="text-4xl font-bold mb-4 text-amber-600">Contact Me</h1>
      <p class="text-lg text-gray-700 max-w-3xl mx-auto">
        I would love to hear from you! Please fill out the form below and I will get back to you as soon as possible.
      </p>
    </div>

    <!-- Contact Form -->
    <form id="contact-form" class="mt-8 space-y-6 lg:space-y-0 lg:grid lg:grid-cols-2 lg:gap-4">
      <!-- Input Name -->
      <div class="flex flex-col col-span-2 lg:col-span-1">
        <label for="name" class="text-sm font-medium text-slate-700">Your Name</label>
        <input type="text" id="name" name="name" required class="p-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-600" />
      </div>
      
      <!-- Input Email -->
      <div class="flex flex-col col-span-2 lg:col-span-1">
        <label for="email" class="text-sm font-medium text-slate-700">Your Email</label>
        <input type="email" id="email" name="email" required class="p-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-600" />
      </div>

      <!-- Input Message -->
      <div class="flex flex-col col-span-2">
        <label for="message" class="text-sm font-medium text-slate-700">Your Message</label>
        <textarea id="message" name="message" required class="p-2 border border-slate-300 rounded-md h-32 focus:outline-none focus:ring-2 focus:ring-amber-600"></textarea>
      </div>

      <!-- Submit Button -->
      <div class="col-span-2 text-center">
        <button 
          type="submit" 
          class="bg-amber-600 text-white p-3 rounded-md hover:bg-amber-700 w-full lg:w-auto"
        >
          Send Message
        </button>
      </div>
    </form>
  </section>

  <!-- Menautkan Script Eksternal -->
  <script src="/js/contact.js" type="module"></script>
</BaseLayout>
